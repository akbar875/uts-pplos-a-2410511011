PORT=8080

# URL masing-masing service
AUTH_SERVICE_URL=http://localhost:3001
PERPUSTAKAAN_SERVICE_URL=http://localhost:8000
MEMBER_SERVICE_URL=http://localhost:3002

# Konfigurasi JWT
JWT_SECRET=supersecretjwtkey_minimal32karakter
JWT_REFRESH_SECRET=refreshsecretkey_minimal32karakter

# Rate limiting: maksimal 60 request per 60000ms (1 menit) per IP
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
